{
  "uid": "observabilidad-lab",
  "title": "Observabilidad — Laboratorio IaC",
  "tags": ["laboratorio", "iac", "observabilidad"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "nivel",
        "label": "Nivel de log (app)",
        "type": "custom",
        "query": "Todos : .+, INFO, WARN, ERROR",
        "current": { "text": "Todos", "value": ".+" },
        "options": [
          { "text": "Todos", "value": ".+", "selected": true },
          { "text": "INFO", "value": "INFO", "selected": false },
          { "text": "WARN", "value": "WARN", "selected": false },
          { "text": "ERROR", "value": "ERROR", "selected": false }
        ],
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU contenedor backend (%)",
      "description": "Uso de CPU del contenedor lab-backend medido por cAdvisor. 100 ≈ un núcleo completo. Umbral de alarma en 50%.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(container_cpu_usage_seconds_total{name=\"lab-backend\"}[1m])) * 100",
          "legendFormat": "CPU lab-backend"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 50 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU del host (%)",
      "description": "Uso de CPU de toda la máquina (node-exporter): 100% − tiempo idle promedio de todos los núcleos.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "CPU host"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "off" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      }
    },
    {
      "id": 3,
      "type": "logs",
      "title": "Logs de aplicación (API + frontend)",
      "description": "Logs JSON del backend y frontend (tier=application). Usa la variable 'Nivel de log' arriba para filtrar por INFO/WARN/ERROR.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "expr": "{tier=\"application\"} | json | level=~\"$nivel\"",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Logs de infraestructura",
      "description": "Logs de los componentes del stack: Prometheus, Loki, Grafana, Alloy, exporters (tier=infrastructure). Aquí aparece también el log del webhook de la alarma.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 9 },
      "targets": [
        {
          "refId": "A",
          "expr": "{tier=\"infrastructure\"}",
          "queryType": "range"
        },
        {
          "refId": "B",
          "expr": "{tier=\"application\"} |= `grafana_alert_received`",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
